# SQL Server
DB_SERVER=localhost
DB_DATABASE=SmartParking
DB_PORT=1433
DB_USER=smartparking_app
DB_PASSWORD=change-me
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
