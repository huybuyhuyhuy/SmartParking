ALLOW_MEMORY_FALLBACK=true

# Optional infrastructure
REDIS_URL=redis://127.0.0.1:6379
KAFKA_ENABLED=false
KAFKA_BROKER=127.0.0.1:9092

# API
PORT=3002
SENSOR_API_KEY=change-me
GATE_API_KEY=change-me
JWT_SECRET=change-me
QR_JWT_SECRET=change-me
# Demo only. Set false in production.
DEMO_DIRECT_PAYMENT_ENABLED=true
