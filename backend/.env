# Cau hinh backend - Smart Parking Hue

# SQL Server
DB_SERVER=localhost
DB_DATABASE=SmartParking
DB_PORT=1433

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Kafka: tat trong che do demo neu chua dung
KAFKA_ENABLED=false
KAFKA_BROKER=127.0.0.1:9092

# API
PORT=3002
SENSOR_API_KEY=hue-iot-key
JWT_SECRET=smart-parking-hue-jwt-secret
QR_JWT_SECRET=smart-parking-hue-qr-secret
