          "endsPattern": ".*ready in.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "start:all",
      "dependsOn": ["backend:api", "frontend:user-map", "frontend:digitalization-tool", "frontend:ioc-dashboard", "frontend:booking"],
      "dependsOrder": "parallel"
    }
  ]
}
